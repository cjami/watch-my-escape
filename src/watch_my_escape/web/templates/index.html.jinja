<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ app_name }}</title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script id="app-data" type="application/json">
      {{ {"models": model_presets, "maps": premade_maps} | tojson }}
    </script>
    <script type="module" src="/static/app.js"></script>
  </head>
  <body>
    <main class="min-h-screen overflow-hidden">
      <section id="splash-screen" class="screen splash-screen is-active" data-screen="splash" aria-label="{{ app_name }}">
        <h1 class="splash-title" aria-label="Watch My Escape">
          <span>WATCH</span>
          <span>MY</span>
          <span>ESCAPE</span>
        </h1>
      </section>

      <section id="menu-screen" class="screen select-screen" data-screen="menu" aria-labelledby="menu-title">
        <div class="select-shell">
          <header class="select-header">
            <p class="brand-mark">{{ app_name }}</p>
            <h1 id="menu-title">Main Menu</h1>
          </header>
          <div class="option-grid" aria-label="Main menu">
            <button id="play-game" type="button" class="selection-card">
              <span class="selection-chip"></span>
              <span class="selection-title">Play Game</span>
              <span class="selection-meta">Choose a model and bundled room.</span>
              <span class="selection-detail">Watch an LLM try to solve a finished escape map.</span>
            </button>
            <button id="open-editor" type="button" class="selection-card">
              <span class="selection-chip"></span>
              <span class="selection-title">Map Editor</span>
              <span class="selection-meta">Build and export a room.</span>
              <span class="selection-detail">Place entities, configure behaviours, validate, and download JSON.</span>
            </button>
          </div>
        </div>
      </section>

      <section id="model-screen" class="screen select-screen" data-screen="models" aria-labelledby="model-title">
        <div class="select-shell model-select-shell">
          <header class="select-header">
            <p class="brand-mark">{{ app_name }}</p>
            <h1 id="model-title">Select Model</h1>
          </header>
          <div id="model-options" class="model-selector" aria-label="Model presets" tabindex="0">
            <button id="previous-model" type="button" class="model-nav-button" aria-label="Previous model">‹</button>
            <section class="model-arena" aria-live="polite">
              <div id="model-lineup" class="model-lineup"></div>
              <div class="model-agent-stage">
                <div id="model-agent-orbit" class="model-agent-orbit">
                  <span id="model-agent-icon" class="model-agent-icon"></span>
                </div>
              </div>
              <div class="model-readout">
                <p id="model-company" class="brand-mark"></p>
                <h2 id="model-name"></h2>
                <div id="model-stats" class="model-stats"></div>
                <p id="model-file" class="model-file"></p>
              </div>
              <button id="choose-model" type="button" class="primary-button model-choose-button">Choose Agent</button>
            </section>
            <button id="next-model" type="button" class="model-nav-button" aria-label="Next model">›</button>
          </div>
        </div>
      </section>

      <section id="map-screen" class="screen select-screen" data-screen="maps" aria-labelledby="map-title">
        <div class="select-shell">
          <header class="select-header">
            <p id="selected-model-label" class="brand-mark"></p>
            <h1 id="map-title">Select Map</h1>
          </header>
          <div id="map-options" class="option-grid" aria-label="Premade maps"></div>
        </div>
      </section>

      <section id="game-screen" class="screen game-screen" data-screen="game" aria-label="Puzzle room">
        <div class="game-layout">
          <section class="room-stage grid content-start gap-4 border border-white/10 p-4" aria-label="Puzzle room map">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="m-0 text-xs font-bold uppercase text-mechanism">WATCH MY ESCAPE</p>
                <p id="game-selection-label" class="m-0 mt-1 text-sm text-[#c4cbc1]"></p>
              </div>
              <div class="flex gap-3 font-mono text-sm text-[#e8ece4]">
                <output id="position">Position: --</output>
                <output id="sanity">Sanity: 100</output>
              </div>
            </div>
            <div class="crt-frame" aria-label="CRT display">
              <div id="map-view" class="map-view" aria-live="polite">
                <span class="map-empty">.</span>
              </div>
              <div id="escape-banner" class="escape-banner" hidden>
                <div class="escape-victory">
                  <span class="escape-agent" aria-hidden="true">
                    <span id="escape-agent-icon" class="escape-agent-icon"></span>
                  </span>
                  <span class="escape-message" aria-label="I did it">
                    <span class="escape-word">I</span>
                    <span class="escape-word">DID</span>
                    <span class="escape-word">IT</span>
                  </span>
                </div>
              </div>
              <div id="game-intro" class="game-intro" aria-hidden="true" hidden>
                <div class="game-intro-screen" aria-label="Game startup sequence">
                  <span>WATCH</span>
                  <span>MY</span>
                  <span>ESCAPE</span>
                </div>
              </div>
            </div>
          </section>

          <section class="grid content-start gap-4" aria-labelledby="console-title">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <h1 id="console-title" class="m-0 text-4xl leading-none tracking-normal">{{ project_description }}</h1>
              <button id="restart-flow" type="button" class="secondary-button">Change Setup</button>
            </div>
            <button id="run-escape" type="button" class="primary-button justify-self-start">Run Escape</button>
            <output id="status" class="min-h-14 border-l-3 border-mechanism bg-white/10 p-4 text-[#e8ece4]">Ready.</output>

            <section class="panel-section" aria-labelledby="visible-entities-title">
              <h2 id="visible-entities-title">Visible Entities</h2>
              <pre id="visible-entities">- None.</pre>
            </section>

            <section class="panel-section" aria-labelledby="inventory-title">
              <h2 id="inventory-title">Inventory</h2>
              <pre id="inventory">- Empty.</pre>
            </section>

            <section class="panel-section" aria-labelledby="journal-title">
              <h2 id="journal-title">Journal</h2>
              <pre id="journal">- No notes recorded.</pre>
            </section>

            <section class="panel-section" aria-labelledby="transcript-title">
              <h2 id="transcript-title">Transcript</h2>
              <pre id="transcript" class="max-h-96 overflow-auto whitespace-pre-wrap">The model has not tried the room yet.</pre>
            </section>
          </section>
        </div>
      </section>

      <section id="editor-screen" class="screen editor-screen" data-screen="editor" aria-label="Map editor">
        <div class="editor-layout">
          <header class="editor-toolbar">
            <div>
              <p class="brand-mark">{{ app_name }}</p>
              <h1>Map Editor</h1>
            </div>
            <div class="editor-actions">
              <button id="editor-back" type="button" class="secondary-button">Menu</button>
              <button id="import-map" type="button" class="secondary-button">Import JSON</button>
              <input id="import-map-file" type="file" accept="application/json,.json" hidden />
              <button id="export-map" type="button" class="primary-button">Export JSON</button>
            </div>
          </header>

          <section class="editor-stage" aria-label="Room builder">
            <div class="editor-sidebar" aria-label="Editor tools">
              <label>
                <span>Map Name</span>
                <input id="editor-map-name" type="text" value="New Escape Room" />
              </label>
              <label>
                <span>Map Id</span>
                <input id="editor-map-id" type="text" value="new-escape-room" />
              </label>
              <label>
                <span>Description</span>
                <textarea id="editor-description" rows="3">A manually authored escape room.</textarea>
              </label>
              <div>
                <span class="field-label">Tool</span>
                <div class="tool-strip" role="group" aria-label="Editor tool">
                  <button type="button" class="tool-button is-selected" data-editor-tool="select">Select</button>
                  <button type="button" class="tool-button" data-editor-tool="place">Place</button>
                  <button type="button" class="tool-button" data-editor-tool="erase">Erase</button>
                  <button type="button" class="tool-button" data-editor-tool="start">Start</button>
                </div>
              </div>
              <div>
                <span class="field-label">Presets</span>
                <div id="entity-presets" class="preset-grid" aria-label="Entity presets"></div>
              </div>
              <output id="editor-status" class="editor-status">Ready.</output>
            </div>

            <div class="editor-map-shell">
              <div id="editor-grid" class="editor-grid" aria-label="Editable 16 by 16 room grid"></div>
            </div>

            <aside class="entity-panel" aria-label="Selected entity">
              <div class="panel-heading">
                <h2>Entity</h2>
                <button id="add-entity" type="button" class="secondary-button">New</button>
              </div>
              <div id="entity-form" class="entity-form"></div>
              <section class="behavior-panel" aria-label="Behaviors">
                <div class="panel-heading">
                  <h2>Behaviors</h2>
                  <button id="add-behavior" type="button" class="secondary-button">Add</button>
                </div>
                <div id="behavior-list" class="behavior-list"></div>
              </section>
            </aside>
          </section>
        </div>
      </section>
    </main>
  </body>
</html>
