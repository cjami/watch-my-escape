<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ app_name }}</title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script type="module" src="/static/app.js"></script>
  </head>
  <body>
    <main class="grid min-h-screen w-[min(1180px,calc(100%-2rem))] grid-cols-1 gap-6 py-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,420px)] lg:gap-8 mx-auto">
      <section class="room-stage grid min-h-90 content-start gap-4 border border-white/10 p-4 lg:min-h-140" aria-label="Puzzle room">
        <div class="flex items-center justify-between gap-3">
          <p class="m-0 text-xs font-bold uppercase tracking-[.12em] text-mechanism">{{ app_name }}</p>
          <div class="flex gap-3 font-mono text-sm text-[#e8ece4]">
            <output id="position">Position: --</output>
            <output id="sanity">Sanity: 100</output>
          </div>
        </div>
        <div id="map-view" class="map-view rounded-md border border-white/10 bg-black/25 p-3" aria-live="polite">
          <span class="map-empty">Run the model to reveal the room map.</span>
        </div>
      </section>

      <section class="grid content-start gap-4" aria-labelledby="console-title">
        <h1 id="console-title" class="m-0 text-4xl leading-none tracking-normal">{{ project_description }}</h1>
        <button id="run-escape" type="button" class="justify-self-start rounded-md bg-mechanism px-4 py-3 font-extrabold text-[#171812]">Run model escape</button>
        <output id="status" class="min-h-14 border-l-3 border-mechanism bg-white/10 p-4 text-[#e8ece4]">Waiting for a configured model.</output>

        <section class="grid gap-2" aria-labelledby="visible-entities-title">
          <h2 id="visible-entities-title" class="m-0 text-sm font-bold uppercase tracking-[.12em] text-[#c4cbc1]">Visible Entities</h2>
          <pre id="visible-entities" class="min-h-20 rounded-md border border-white/10 bg-white/10 p-3 text-sm">- None.</pre>
        </section>

        <section class="grid gap-2" aria-labelledby="inventory-title">
          <h2 id="inventory-title" class="m-0 text-sm font-bold uppercase tracking-[.12em] text-[#c4cbc1]">Inventory</h2>
          <pre id="inventory" class="min-h-16 rounded-md border border-white/10 bg-white/10 p-3 text-sm">- Empty.</pre>
        </section>

        <section class="grid gap-2" aria-labelledby="journal-title">
          <h2 id="journal-title" class="m-0 text-sm font-bold uppercase tracking-[.12em] text-[#c4cbc1]">Journal</h2>
          <pre id="journal" class="min-h-20 rounded-md border border-white/10 bg-white/10 p-3 text-sm">- No notes recorded.</pre>
        </section>

        <section class="grid gap-2" aria-labelledby="transcript-title">
          <h2 id="transcript-title" class="m-0 text-sm font-bold uppercase tracking-[.12em] text-[#c4cbc1]">Transcript</h2>
          <pre id="transcript" class="max-h-96 overflow-auto rounded-md border border-white/10 bg-black/25 p-3 text-sm whitespace-pre-wrap">The model has not tried the room yet.</pre>
        </section>
      </section>
    </main>
  </body>
</html>
