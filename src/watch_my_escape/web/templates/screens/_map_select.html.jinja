<section id="map-screen" class="screen select-screen" data-screen="maps" aria-labelledby="map-title">
  <div class="select-shell map-select-shell">
    <header class="select-header">
      <div>
        <p id="selected-model-label" class="brand-mark"></p>
        <h1 id="map-title">Select Map</h1>
      </div>
      <button id="map-back" type="button" class="secondary-button">Back</button>
    </header>
    <div class="map-selector">
      <div id="map-options" class="map-option-list" aria-label="Premade maps"></div>
      <section class="map-preview-panel" aria-labelledby="map-preview-title">
        <div id="map-preview" class="map-view map-preview" aria-label="Selected map preview"></div>
        <div class="map-preview-copy">
          <h2 id="map-preview-title"></h2>
          <p id="map-preview-description"></p>
        </div>
      </section>
    </div>
  </div>
</section>
