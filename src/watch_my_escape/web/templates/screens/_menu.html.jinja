<section id="menu-screen" class="screen select-screen" data-screen="menu" aria-labelledby="menu-title">
  <div class="select-shell">
    <header class="select-header">
      <p class="brand-mark">{{ app_name }}</p>
      <h1 id="menu-title">Main Menu</h1>
    </header>
    <div class="option-grid" aria-label="Main menu">
      <button id="play-game" type="button" class="selection-card">
        <span class="selection-chip"></span>
        <span class="selection-title">Play Game</span>
        <span class="selection-meta">Choose a model and bundled room.</span>
        <span class="selection-detail">Watch an LLM try to solve a finished escape map.</span>
      </button>
      <button id="open-editor" type="button" class="selection-card">
        <span class="selection-chip"></span>
        <span class="selection-title">Map Editor</span>
        <span class="selection-meta">Build and export a room.</span>
        <span class="selection-detail">Place entities, configure behaviours, validate, and download JSON.</span>
      </button>
    </div>
  </div>
</section>
