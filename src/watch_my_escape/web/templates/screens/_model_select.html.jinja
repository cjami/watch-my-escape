<section id="model-screen" class="screen select-screen" data-screen="models" aria-labelledby="model-title">
  <div class="select-shell model-select-shell">
    <header class="select-header">
      <div>
        <p class="brand-mark">{{ app_name }}</p>
        <h1 id="model-title">Select Model</h1>
      </div>
      <button id="model-menu" type="button" class="secondary-button">Menu</button>
    </header>
    <div id="model-options" class="model-selector" aria-label="Model presets" tabindex="0">
      <section class="model-arena" aria-live="polite">
        <div id="model-lineup" class="model-lineup"></div>
        <div class="model-agent-stage">
          <button id="previous-model" type="button" class="model-nav-button model-nav-previous" aria-label="Previous model">&lsaquo;</button>
          <div id="model-agent-orbit" class="model-agent-orbit">
            <span id="model-agent-icon" class="model-agent-icon"></span>
          </div>
          <button id="next-model" type="button" class="model-nav-button model-nav-next" aria-label="Next model">&rsaquo;</button>
        </div>
        <div class="model-readout">
          <p id="model-company" class="brand-mark"></p>
          <div class="model-title-anchor">
            <h2 id="model-name"></h2>
            <div id="model-advanced-settings" class="model-advanced-settings" hidden>
              <div class="model-setting-row">
                <div class="model-setting-copy">
                  <span class="model-setting-label">Thinking</span>
                </div>
                <button id="model-thinking-toggle" type="button" class="model-toggle" aria-pressed="true">On</button>
              </div>
              <div class="model-setting-row model-temperature-row">
                <span class="model-setting-label">Temperature</span>
                <div class="model-temperature-stepper" role="group" aria-label="Temperature">
                  <button
                    id="model-temperature-down"
                    type="button"
                    class="model-stepper-button"
                    aria-label="Decrease temperature"
                  >&lsaquo;</button>
                  <output id="model-temperature-value" class="model-setting-value">1.00</output>
                  <button
                    id="model-temperature-up"
                    type="button"
                    class="model-stepper-button"
                    aria-label="Increase temperature"
                  >&rsaquo;</button>
                </div>
              </div>
            </div>
          </div>
          <div class="model-stats-shell">
            <div id="model-stats" class="model-stats"></div>
            <button
              id="model-settings-toggle"
              type="button"
              class="model-settings-button"
              aria-label="Advanced settings for selected model"
              aria-expanded="false"
              aria-controls="model-advanced-settings"
            >&#9881;</button>
          </div>
          <p id="model-file" class="model-file"></p>
        </div>
        <button id="choose-model" type="button" class="primary-button model-choose-button">Choose Agent</button>
      </section>
    </div>
  </div>
</section>
